# .semgrepignore
# Files and directories Semgrep should skip.
# Syntax mirrors .gitignore.

# Dependencies
node_modules/
vendor/
.venv/
venv/
__pycache__/
*.pyc

# Build artifacts
dist/
build/
out/
target/
*.min.js
*.bundle.js
*.map

# Test fixtures (may contain intentionally bad code)
# tests/fixtures/
# spec/fixtures/

# Lock files (large, no scannable logic)
package-lock.json
yarn.lock
Pipfile.lock
poetry.lock
Gemfile.lock
go.sum
composer.lock

# Generated code
*.pb.go
*.pb.py
*_pb2.py
*_grpc.py

# Third-party vendored code
third_party/
extern/

# IDE / OS artifacts
.idea/
.vscode/
.DS_Store
*.swp
